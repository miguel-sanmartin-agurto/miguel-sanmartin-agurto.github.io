---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
---

<Layout title="Blog Técnico | Miguel San Martín">
  <main class="pt-32 pb-12 container mx-auto px-6 max-w-4xl">
    
    <div class="mb-8">
      <a 
        href="/" 
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-emerald-500/30 bg-emerald-500/5 text-emerald-500 text-sm hover:bg-emerald-500/20 transition-all duration-300 shadow-sm"
      >
        <span class="text-lg">←</span> Volver al Portfolio
      </a>
    </div>

    <h1 class="text-4xl font-bold text-emerald-500 mb-2">Bitácora de Ingeniería</h1>
    <p class="text-muted-foreground mb-10 italic">Documentación técnica sobre electrónica de potencia y diseño de hardware.</p>
    
    {posts.length === 0 ? (
      <div class="p-8 border border-dashed border-emerald-500/20 rounded-lg text-center">
        <p class="text-muted-foreground">Aún no hay artículos publicados. ¡Vuelve pronto!</p>
      </div>
    ) : (
      <div class="grid gap-6">
        {posts.map(post => (
          <a 
            href={`/blog/${post.slug}`} 
            class="group block p-6 border border-emerald-500/10 rounded-xl bg-card/50 backdrop-blur-sm hover:border-emerald-500/40 transition-all duration-300 shadow-md"
          >
            <div class="flex justify-between items-start mb-2">
              <h2 class="text-2xl font-bold text-white group-hover:text-emerald-400 transition-colors">
                {post.data.title}
              </h2>
              <span class="text-xs font-mono text-emerald-500/60 bg-emerald-500/5 px-2 py-1 rounded border border-emerald-500/10">
                {post.data.pubDate.toLocaleDateString('es-CL')}
              </span>
            </div>
            <p class="text-muted-foreground line-clamp-2">
              {post.data.description}
            </p>
            <div class="mt-4 text-emerald-500 text-sm font-medium flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
              Leer artículo completo <span>→</span>
            </div>
          </a>
        ))}
      </div>
    )}
  </main>
</Layout>